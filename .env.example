# ── DB Backend: "local" or "supabase" ─────────────────────────────────────────
DB_BACKEND=supabase

# ── Local PostgreSQL ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:@localhost:5432/VCrypto

# ── Supabase ───────────────────────────────────────────────────────────────────
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
# Optional: paste a full connection string here to override all params above
DB_URL=

# ── Messari API (free tier — no key required for basic endpoints) ──────────────
MESSARI_API_KEY=
MESSARI_BASE_URL=https://api.messari.io

# ── CoinGecko API (free tier — no key required) ────────────────────────────────
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ── Assets to track (slugs that work for both CoinGecko and Messari) ─────────
TRACKED_ASSETS=bitcoin,ethereum,solana,cardano,polkadot,avalanche-2,chainlink,uniswap,polygon-ecosystem-token,cosmos

# ── Scheduler intervals (seconds) ─────────────────────────────────────────────
SCHEDULER_ENABLED=true
GLOBAL_METRICS_INTERVAL_SECONDS=3600
ASSET_METRICS_INTERVAL_SECONDS=3600
ASSET_LIST_INTERVAL_SECONDS=86400
ASSET_PROFILE_INTERVAL_SECONDS=604800
PRICE_HISTORY_INTERVAL_SECONDS=86400

# ── Price history lookback (days) ─────────────────────────────────────────────
PRICE_HISTORY_LOOKBACK_DAYS=30

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/messari.log
